# YepAI Application
# Use bot-test.yepai.io for testing, app.yepai.io for production
YEPAI_BASE_URL=https://bot-test.yepai.io

# Login credentials (for page testing flows)
YEPAI_LOGIN_EMAIL=your-login-email@example.com
YEPAI_LOGIN_PASSWORD=your-login-password

# Registration test credentials (for registration flow)
YEPAI_TEST_EMAIL=test@example.com
YEPAI_TEST_PASSWORD=SecurePassword123!
YEPAI_TEST_FIRST_NAME=Test
YEPAI_TEST_LAST_NAME=User
YEPAI_TEST_ORGANIZATION=Test Organization

# Gmail API (OAuth + Refresh Token)
# Get these from Google Cloud Console: https://console.cloud.google.com
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token
GMAIL_TARGET_EMAIL=your-gmail@gmail.com

# Shopify Partner Account
SHOPIFY_STORE_URL=your-dev-store.myshopify.com
SHOPIFY_EMAIL=partner@example.com
SHOPIFY_PASSWORD=your-shopify-password
SHOPIFY_SELECTED_PLAN=basic

# Slack Integration
# Incoming Webhook URL (Notifications: report-html, triage-agent, change-watch-agent)
# Create at: https://api.slack.com/apps → Your App → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Signing Secret (Slash command bot — verifies requests are from Slack)
# Found at: https://api.slack.com/apps → Your App → Basic Information
SLACK_SIGNING_SECRET=your-signing-secret

# Port for the slash command bot server (default: 3100)
SLACK_BOT_PORT=3100

# Accuracy alert threshold % (default: 80)
# alert-agent sends Slack alert if any agent falls below this
ACCURACY_ALERT_THRESHOLD=80

# Automation Options
HEADLESS=false
SLOWMO=100
TIMEOUT=30000
SCREENSHOT_ON_FAILURE=true
