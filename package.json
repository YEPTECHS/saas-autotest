{
  "name": "yepai-e2e-automation",
  "version": "1.0.0",
  "description": "AI-driven E2E automation framework for YepAI",
  "type": "module",
  "main": "dist/cli/index.js",
  "bin": {
    "yepai-e2e": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli/index.ts",
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "cli": "tsx src/cli/index.ts",
    "flow": "tsx src/cli/index.ts run",
    "users": "tsx src/cli/index.ts users",
    "users:json": "tsx src/cli/index.ts users --json",
    "list": "tsx src/cli/index.ts list",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "shopify:create": "tsx src/actions/shopify/create-store-fast.ts",
    "shopify:cdp": "tsx src/actions/shopify/create-store-cdp.ts",
    "shopify:ui": "tsx src/web/server.ts",
    "skill:shopify-create": "tsx skills/shopify-create/index.ts",
    "test:cc": "tsx scripts/test-concurrency.ts",
    "test:is": "tsx scripts/test-isolation.ts",
    "test:cc:maya": "tsx scripts/test-concurrency.ts --agent maya",
    "test:cc:oscar": "tsx scripts/test-concurrency.ts --agent oscar",
    "test:cc:daniel": "tsx scripts/test-concurrency.ts --agent daniel",
    "test:is:maya": "tsx scripts/test-isolation.ts --agent maya",
    "test:is:oscar": "tsx scripts/test-isolation.ts --agent oscar",
    "test:is:daniel": "tsx scripts/test-isolation.ts --agent daniel",
    "test:stress": "tsx scripts/test-stress.ts",
    "test:stress:maya": "tsx scripts/test-stress.ts --agent maya",
    "test:stress:oscar": "tsx scripts/test-stress.ts --agent oscar",
    "test:stress:daniel": "tsx scripts/test-stress.ts --agent daniel",
    "test:tab": "tsx scripts/test-tab-isolation.ts",
    "test:tab:maya": "tsx scripts/test-tab-isolation.ts --agent maya",
    "test:tab:oscar": "tsx scripts/test-tab-isolation.ts --agent oscar",
    "test:tab:daniel": "tsx scripts/test-tab-isolation.ts --agent daniel",
    "test:tab:cody": "tsx scripts/test-tab-isolation.ts --agent cody",
    "test:sync": "tsx scripts/test-tab-sync.ts",
    "test:sync:maya": "tsx scripts/test-tab-sync.ts --agent maya",
    "test:sync:oscar": "tsx scripts/test-tab-sync.ts --agent oscar",
    "test:sync:daniel": "tsx scripts/test-tab-sync.ts --agent daniel",
    "stress:api": "tsx scripts/stress-test-api.ts",
    "stress:api:maya": "tsx scripts/stress-test-api.ts --agent maya",
    "stress:api:oscar": "tsx scripts/stress-test-api.ts --agent oscar",
    "stress:api:daniel": "tsx scripts/stress-test-api.ts --agent daniel",
    "stress:api:cody": "tsx scripts/stress-test-api.ts --agent cody",
    "stress:advanced": "tsx scripts/stress-test-api-advanced.ts",
    "stress:advanced:maya": "tsx scripts/stress-test-api-advanced.ts --agent maya",
    "stress:advanced:oscar": "tsx scripts/stress-test-api-advanced.ts --agent oscar",
    "stress:advanced:daniel": "tsx scripts/stress-test-api-advanced.ts --agent daniel",
    "accuracy": "tsx scripts/accuracy-test-api.ts --agent all",
    "accuracy:maya": "tsx scripts/accuracy-test-api.ts --agent maya",
    "accuracy:oscar": "tsx scripts/accuracy-test-api.ts --agent oscar",
    "accuracy:daniel": "tsx scripts/accuracy-test-api.ts --agent daniel",
    "accuracy:cody": "tsx scripts/accuracy-test-api.ts --agent cody",
    "phase1:tc2": "tsx src/cli/index.ts run phase1-tc2-sync-now",
    "phase1:tc3": "tsx src/cli/index.ts run phase1-tc3-filtered-sync",
    "phase1:tc4": "tsx scripts/phase1-tc4-concurrent.ts",
    "phase1:tc7": "tsx src/cli/index.ts run phase1-tc7-regression",
    "phase1:all": "tsx src/cli/index.ts run phase1-tc2-sync-now && tsx src/cli/index.ts run phase1-tc3-filtered-sync && tsx scripts/phase1-tc4-concurrent.ts && tsx src/cli/index.ts run phase1-tc7-regression",
    "phase1:report": "tsx scripts/phase1-slack-report.ts",
    "analyze:screenshots": "tsx scripts/analyze-screenshots.ts",
    "generate:flow": "tsx scripts/generate-flow.ts",
    "report:html": "tsx scripts/report-html.ts",
    "report:html:slack": "tsx scripts/report-html.ts --slack",
    "report:html:email": "tsx scripts/report-html.ts --email",
    "report:html:all": "tsx scripts/report-html.ts --slack --email",
    "generate:accuracy": "tsx scripts/generate-accuracy-tests.ts",
    "test:boundary:maya": "tsx src/cli/index.ts run test-marketing-boundary",
    "test:boundary:oscar": "tsx src/cli/index.ts run test-operation-boundary",
    "test:boundary:daniel": "tsx src/cli/index.ts run test-daniel-boundary",
    "test:boundary:cody": "tsx src/cli/index.ts run test-cody-boundary",
    "test:comprehensive:cody": "tsx src/cli/index.ts run test-cody-comprehensive",
    "qa:agent": "tsx scripts/qa-agent.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@playwright/test": "^1.40.0",
    "@types/nodemailer": "^8.0.0",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "googleapis": "^128.0.0",
    "nodemailer": "^8.0.7",
    "open": "^11.0.0",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "e2e",
    "automation",
    "playwright",
    "ai",
    "testing"
  ],
  "license": "MIT"
}
